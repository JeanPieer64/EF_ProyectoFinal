<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Ofertas de Empleo</title>
    <style>
        body { font-family: Arial, sans-serif; padding: 40px 20px; background-color: #f4f6f8; color: #000; }
        
        /* Aumentamos el tamaño del contenedor principal a 1050px y mejoramos el padding */
        .pizarra-container { border: 2px solid #000; padding: 40px 50px; width: 1050px; margin: auto; background-color: #fff; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); }
        
        /* Cabecera más grande y espaciada */
        .header { display: flex; justify-content: center; align-items: center; gap: 30px; font-size: 28px; margin-bottom: 40px; letter-spacing: 1px; font-weight: bold; }
        .header button { padding: 8px 25px; border: 2px solid #000; background: transparent; cursor: pointer; border-radius: 8px; font-weight: bold; text-transform: uppercase; font-size: 15px; }
        
        /* Sistema de filas y columnas más holgado */
        .row { display: flex; margin-bottom: 18px; align-items: center; }
        .col { display: flex; flex-direction: column; }
        
        /* Etiquetas e inputs más grandes y legibles */
        label { font-size: 15px; font-weight: normal; margin-right: 10px; }
        .input-label { width: 100px; } /* Ancho fijo para alinear los inputs de la izquierda */
        
        input[type="text"], input[type="number"] { padding: 8px 12px; border: 1px solid #888; border-radius: 4px; font-size: 15px; outline: none; }
        input[type="text"]:focus, input[type="number"]:focus { border-color: #000; }
        
        /* Títulos de sección */
        .section-title { text-transform: uppercase; margin-bottom: 15px; margin-top: 25px; font-size: 17px; font-weight: bold; }
        
        /* Tabla redimensionada */
        table { width: 100%; border-collapse: collapse; margin-top: 15px; }
        table, th, td { border: 1px solid #000; text-align: center; padding: 10px; font-size: 15px; }
        th { font-weight: bold; }
        
        /* Botones de acción inferiores más grandes */
        .btn-crud { padding: 12px 25px; border: 1px solid #000; background: transparent; cursor: pointer; border-radius: 25px; text-transform: uppercase; font-weight: bold; font-size: 14px; transition: background 0.2s; }
        .btn-crud:hover { background: #e0e0e0; }
        .buttons-bar { display: flex; justify-content: space-around; margin-top: 50px; }

        /* ESTILOS EXCLUSIVOS PARA IMPRESIÓN */
        @media print { 
            .buttons-bar, button { display: none !important; } 
            input[type="text"], input[type="number"] { border: none !important; background: transparent !important; padding: 0 !important; font-family: Arial, sans-serif !important; }
            body, .pizarra-container { background-color: white !important; border: none !important; box-shadow: none !important; width: 100% !important; padding: 0 !important; margin: 0 !important; }
        }
    </style>
</head>
<body>

<div class="pizarra-container">
    
    <div class="header">
        OFERTAS DE EMPLEO
        <button type="button" onclick="window.open('/lista', '_self')">Lista / Elegir</button>
    </div>

    <form action="/" method="GET" id="formBuscar">
        <div class="row" style="margin-bottom: 35px;">
            <div style="display: flex; align-items: center; width: 35%;">
                <label style="width: 60px;">Nro ID:</label>
                <input type="number" name="buscarId" id="nroId" style="width: 80px;" 
                       value="<%= typeof oferta !== 'undefined' && oferta ? oferta.NroId : '' %>" 
                       onkeydown="if(event.key === 'Enter') { event.preventDefault(); if(this.value != 0) this.form.submit(); }">
                <button type="button" onclick="crearNuevo()" style="margin-left: 15px; padding: 7px 15px; cursor: pointer; border: 1px solid #000; background: transparent; border-radius: 4px;">Nuevo</button>
            </div>
            
            <div style="display: flex; align-items: center; width: 65%;">
                <label style="width: 60px;">Puesto:</label>
                <!-- Usamos flex: 1 para que el input ocupe todo el espacio sobrante -->
                <input type="text" id="puesto" style="flex: 1;" value="<%= typeof oferta !== 'undefined' && oferta ? oferta.Puesto : '' %>">
            </div>
        </div>
    </form>

    <div class="row" style="align-items: flex-start; justify-content: space-between;">
        
        <!-- COLUMNA IZQUIERDA -->
        <div class="col" style="width: 40%;">
            <div class="section-title">EMPRESA</div>
            <div class="row"><label class="input-label">Razon Soc.:</label> <input type="text" id="razonSoc" style="flex: 1;" value="<%= typeof oferta !== 'undefined' && oferta && oferta.Empresa ? oferta.Empresa.RazonSoc : '' %>"></div>
            <div class="row"><label class="input-label">Dirección:</label> <input type="text" id="direccion" style="flex: 1;" value="<%= typeof oferta !== 'undefined' && oferta && oferta.Empresa ? oferta.Empresa.Direccion : '' %>"></div>
            <div class="row"><label class="input-label">Distrito:</label> <input type="text" id="distrito" style="flex: 1;" value="<%= typeof oferta !== 'undefined' && oferta && oferta.Empresa ? oferta.Empresa.Distrito : '' %>"></div>

            <div class="row" style="margin-top: 40px;"><label class="input-label">Experiencia:</label> <input type="number" id="experiencia" style="flex: 1;" value="<%= typeof oferta !== 'undefined' && oferta ? oferta.Experiencia : '' %>"></div>
            <div class="row"><label class="input-label">Pago Mes:</label> <input type="number" id="pagoMes" style="flex: 1;" value="<%= typeof oferta !== 'undefined' && oferta ? oferta.PagoMensual : '' %>"></div>
        </div>

        <!-- COLUMNA DERECHA -->
        <div class="col" style="width: 55%;">
            <div class="section-title">REQUISITOS</div>
            <div class="row"><label style="width: 90px;">Formación:</label> <input type="text" id="formacion" style="flex: 1;" value="<%= typeof oferta !== 'undefined' && oferta && oferta.Requisitos ? oferta.Requisitos.Formacion : '' %>"></div>
            
            <div class="section-title" style="display: flex; justify-content: space-between; align-items: center; margin-top: 30px;">
                <span>CONOCIMIENTOS</span> 
                <div style="display: flex; gap: 8px;">
                    <input type="text" id="inputNuevoConoc" placeholder="Ej: Python" style="width: 130px; font-size: 14px; padding: 6px 10px;">
                    <button type="button" onclick="agregarConocimiento()" style="padding: 6px 20px; border-radius: 20px; border: 1px solid #000; background: transparent; cursor: pointer; font-weight: bold;">AÑADIR</button>
                </div>
            </div>
            
            <table>
                <thead>
                    <tr><th style="width: 15%;">Nro</th><th style="width: 50%;">CONOCER</th><th style="width: 35%;">ACCIONES</th></tr>
                </thead>
                <tbody id="tablaConocimientos">
                </tbody>
            </table>
        </div>
    </div>

    <div class="buttons-bar">
        <button class="btn-crud" onclick="guardarOferta()">AÑADIR OFERTA</button>
        <button class="btn-crud" onclick="actualizarOferta()">ACTUALIZAR</button>
        <button class="btn-crud" onclick="eliminarOferta()">ELIMINAR</button>
        <button class="btn-crud" onclick="window.print()">IMPRIMIR</button>
    </div>
</div>

<% 
    let conocimientosEJS = [];
    if (typeof oferta !== 'undefined' && oferta && oferta.Requisitos && oferta.Requisitos.Conocimientos) {
        conocimientosEJS = oferta.Requisitos.Conocimientos;
    }
%>
<input type="hidden" id="datosOcultosEJS" value="<%= JSON.stringify(conocimientosEJS) %>">

<script>
    let listaConocimientos = JSON.parse(document.getElementById('datosOcultosEJS').value);

    function pintarTabla() {
        const tbody = document.getElementById('tablaConocimientos');
        tbody.innerHTML = '';
        if (listaConocimientos.length === 0) {
            tbody.innerHTML = '<tr><td colspan="3">Vacio</td></tr>';
            return;
        }
        listaConocimientos.forEach((conocimiento, index) => {
            tbody.innerHTML += `
                <tr>
                    <td>${index + 1}</td>
                    <td style="text-align: left;">${conocimiento}</td>
                    <td>
                        <button type="button" onclick="editarConocimiento(${index})" style="font-size: 12px; padding: 4px 8px; cursor: pointer; margin-right: 5px;">EDITAR</button>
                        <button type="button" onclick="quitarConocimiento(${index})" style="font-size: 12px; padding: 4px 8px; cursor: pointer;">ELIMINAR</button>
                    </td>
                </tr>
            `;
        });
    }

    function agregarConocimiento() {
        const input = document.getElementById('inputNuevoConoc');
        const nuevo = input.value;
        
        if (nuevo && nuevo.trim() !== "") {
            listaConocimientos.push(nuevo.trim()); 
            pintarTabla(); 
            input.value = ''; 
        } else {
            alert("Por favor, escriba un conocimiento en el campo primero.");
        }
    }

    function editarConocimiento(index) {
        document.getElementById('inputNuevoConoc').value = listaConocimientos[index];
        listaConocimientos.splice(index, 1);
        pintarTabla();
    }

    function quitarConocimiento(index) {
        listaConocimientos.splice(index, 1); 
        pintarTabla(); 
    }

    pintarTabla();

    function obtenerDatosDelFormulario() {
        return {
            NroId: Number(document.getElementById('nroId').value),
            Puesto: document.getElementById('puesto').value,
            Empresa: {
                RazonSoc: document.getElementById('razonSoc').value,
                Direccion: document.getElementById('direccion').value,
                Distrito: document.getElementById('distrito').value
            },
            Experiencia: Number(document.getElementById('experiencia').value),
            PagoMensual: Number(document.getElementById('pagoMes').value),
            Requisitos: {
                Formacion: document.getElementById('formacion').value,
                Conocimientos: listaConocimientos 
            }
        };
    }

    async function crearNuevo() {
        try {
            const res = await fetch('/api/nuevo-id');
            const data = await res.json();
            
            document.querySelectorAll('input:not(#datosOcultosEJS)').forEach(input => input.value = ''); 
            document.getElementById('nroId').value = data.nuevoId; 
            
            listaConocimientos = []; 
            pintarTabla();
        } catch (error) { console.error(error); }
    }

    async function guardarOferta() {
        const datos = obtenerDatosDelFormulario();
        if (!datos.NroId || !datos.Puesto) return alert("Falta ingresar el Nro ID o el Puesto.");

        try {
            const res = await fetch('/api/ofertas', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(datos)
            });
            const resultado = await res.json();
            if (resultado.exito) {
                alert('Oferta creada en el sistema correctamente.');
                window.location.href = `/?buscarId=${datos.NroId}`; 
            } else { alert(resultado.mensaje); }
        } catch (error) { console.error(error); }
    }

    async function actualizarOferta() {
        const datos = obtenerDatosDelFormulario();
        if (!datos.NroId) return alert("Busque una oferta primero para poder actualizarla.");

        try {
            const res = await fetch(`/api/ofertas/${datos.NroId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(datos)
            });
            const resultado = await res.json();
            if (resultado.exito) {
                alert('Oferta actualizada correctamente.');
            }
        } catch (error) { console.error(error); }
    }

    async function eliminarOferta() {
        const id = document.getElementById('nroId').value;
        if (!id) return alert("Ingrese un Nro ID para eliminar.");
        
        if (confirm(`¿Está seguro de eliminar la oferta ID: ${id}?`)) {
            try {
                const res = await fetch(`/api/ofertas/${id}`, { method: 'DELETE' });
                const resultado = await res.json();
                if (resultado.exito) {
                    alert('Oferta eliminada correctamente.');
                    window.location.href = '/'; 
                }
            } catch (error) { console.error(error); }
        }
    }
</script>
</body>
</html>