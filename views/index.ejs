<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Ofertas de Empleo</title>
    <style>
        body { font-family: 'Segoe UI', Roboto, Arial, sans-serif; padding: 0; margin: 0; background-color: #f8fafc; color: #1e293b; }
        
        /* --- BARRA DE NAVEGACIÓN --- */
        .navbar-dark { background-color: #1f2937; color: white; display: flex; justify-content: space-between; align-items: center; padding: 15px 50px; box-shadow: 0 4px 10px rgba(0,0,0,0.3); margin-bottom: 40px; }
        .navbar-dark .nav-brand { font-size: 24px; font-weight: bold; letter-spacing: 1px; color: #fff; }
        .navbar-dark .nav-links { list-style: none; display: flex; gap: 40px; margin: 0; padding: 0; }
        .navbar-dark .nav-links li a { color: #d1d5db; text-decoration: none; font-size: 15px; font-weight: bold; transition: all 0.3s ease; }
        .navbar-dark .nav-links li a:hover { color: #ffffff; text-shadow: 0 0 12px #60a5fa, 0 0 20px #60a5fa; }
        
        /* --- CONTENEDOR PRINCIPAL --- */
        .pizarra-container { max-width: 1050px; margin: auto; background: white; padding: 40px 50px; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); border: 1px solid #f1f5f9; }
        .header { text-align: center; text-transform: uppercase; font-size: 18px; margin-bottom: 35px; color: #0f172a; letter-spacing: 0.5px; border-bottom: 2px solid #e2e8f0; padding-bottom: 15px; font-weight: 800; }
        
        /* --- MAQUETACIÓN E INPUTS --- */
        .row { display: flex; margin-bottom: 18px; align-items: center; }
        .col { display: flex; flex-direction: column; }
        label { font-size: 14px; font-weight: 600; margin-right: 10px; color: #475569; }
        .input-label { width: 100px; }
        
        input[type="text"], input[type="number"] { padding: 10px 15px; border: 1px solid #cbd5e1; border-radius: 6px; font-size: 14px; outline: none; transition: all 0.3s; background-color: #fff; color: #1e293b; }
        input[type="text"]:focus, input[type="number"]:focus { border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,0.2); }
        
        .section-title { text-transform: uppercase; margin-bottom: 20px; margin-top: 25px; font-size: 14px; font-weight: 800; color: #3b82f6; letter-spacing: 0.5px; }
        
        /* --- TABLA INTERNA --- */
        table { width: 100%; border-collapse: separate; border-spacing: 0; margin-top: 15px; border: 1px solid #e2e8f0; border-radius: 8px; overflow: hidden; }
        th, td { padding: 12px; text-align: center; font-size: 13px; }
        th { background-color: #f8fafc; color: #475569; font-weight: 700; text-transform: uppercase; border-bottom: 2px solid #e2e8f0; letter-spacing: 0.5px;}
        td { border-bottom: 1px solid #e2e8f0; }
        tr:last-child td { border-bottom: none; }
        
        /* --- BOTONES PRINCIPALES --- */
        .buttons-bar { display: flex; justify-content: center; gap: 20px; margin-top: 45px; border-top: 2px solid #e2e8f0; padding-top: 30px; }
        .btn-crud { padding: 12px 24px; border: none; cursor: pointer; border-radius: 8px; text-transform: uppercase; font-weight: 700; font-size: 13px; color: white; transition: all 0.2s; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .btn-add { background-color: #10b981; } .btn-add:hover { background-color: #059669; transform: translateY(-2px); }
        .btn-update { background-color: #f59e0b; } .btn-update:hover { background-color: #d97706; transform: translateY(-2px); }
        .btn-delete { background-color: #ef4444; } .btn-delete:hover { background-color: #dc2626; transform: translateY(-2px); }
        .btn-print { background-color: #475569; } .btn-print:hover { background-color: #334155; transform: translateY(-2px); }
        
        /* --- BOTONES SECUNDARIOS --- */
        .btn-secundario { padding: 9px 18px; border: none; border-radius: 6px; cursor: pointer; font-weight: bold; transition: 0.2s; color: white; font-size: 12px; text-transform: uppercase;}
        .btn-nuevo { background-color: #3b82f6; margin-left: 15px; box-shadow: 0 4px 6px rgba(59,130,246,0.2);} .btn-nuevo:hover { background-color: #2563eb; transform: translateY(-1px);}
        .btn-add-conoc { background-color: #3b82f6; box-shadow: 0 4px 6px rgba(59,130,246,0.2);} .btn-add-conoc:hover { background-color: #2563eb; transform: translateY(-1px);}
        
        .btn-tbl { padding: 6px 10px; border: none; border-radius: 4px; color: white; font-size: 11px; font-weight: bold; cursor: pointer; transition: 0.2s; }
        .btn-tbl-edit { background-color: #f59e0b; margin-right: 5px; } .btn-tbl-edit:hover { background-color: #d97706; }
        .btn-tbl-delete { background-color: #ef4444; } .btn-tbl-delete:hover { background-color: #dc2626; }

        #mensaje-feedback { display: none; padding: 15px 30px; background-color: #10b981; color: white; border-radius: 8px; text-align: center; font-weight: bold; font-size: 15px; position: fixed; top: 85px; left: 50%; transform: translateX(-50%); z-index: 9999; box-shadow: 0 10px 20px rgba(16, 185, 129, 0.3); }

        @media print { 
            .navbar-dark, .buttons-bar, .btn-secundario, .btn-tbl { display: none !important; } 
            input[type="text"], input[type="number"] { border: none !important; background: transparent !important; padding: 0 !important; font-family: Arial, sans-serif !important; }
            body, .pizarra-container { background-color: white !important; border: none !important; box-shadow: none !important; width: 100% !important; padding: 0 !important; margin: 0 !important; }
        }
    </style>
</head>
<body>

<nav class="navbar-dark">
    <div class="nav-brand">Portal Empleos Pro</div>
    <ul class="nav-links">
        <li><a href="/">Home (CRUD)</a></li>
        <li><a href="/lista">Lista General</a></li>
        <li><a href="/busqueda">Buscar x Conocimientos</a></li>
    </ul>
</nav>

<div id="mensaje-feedback"></div>

<div class="pizarra-container">
    <div class="header">GESTIÓN DE OFERTAS DE EMPLEO</div>

    <form action="/" method="GET" id="formBuscar">
        <div class="row" style="margin-bottom: 35px;">
            <div style="display: flex; align-items: center; width: 35%;">
                <label style="width: 60px;">Nro ID:</label>
                <input type="number" name="buscarId" id="nroId" style="width: 80px;" 
                       value="<%= typeof oferta !== 'undefined' && oferta ? oferta.NroId : '' %>" 
                       onkeydown="if(event.key === 'Enter') { event.preventDefault(); if(this.value != 0) this.form.submit(); }">
                <button type="button" class="btn-secundario btn-nuevo" onclick="crearNuevo()">NUEVO</button>
            </div>
            
            <div style="display: flex; align-items: center; width: 65%;">
                <label style="width: 60px;">Puesto:</label>
                <input type="text" id="puesto" style="flex: 1;" value="<%= typeof oferta !== 'undefined' && oferta ? oferta.Puesto : '' %>">
            </div>
        </div>
    </form>

    <div class="row" style="align-items: flex-start; justify-content: space-between;">
        <div class="col" style="width: 40%;">
            <div class="section-title">DATOS DE LA EMPRESA</div>
            <div class="row"><label class="input-label">Razón Soc.:</label> <input type="text" id="razonSoc" style="flex: 1;" value="<%= typeof oferta !== 'undefined' && oferta && oferta.Empresa ? oferta.Empresa.RazonSoc : '' %>"></div>
            <div class="row"><label class="input-label">Dirección:</label> <input type="text" id="direccion" style="flex: 1;" value="<%= typeof oferta !== 'undefined' && oferta && oferta.Empresa ? oferta.Empresa.Direccion : '' %>"></div>
            <div class="row"><label class="input-label">Distrito:</label> <input type="text" id="distrito" style="flex: 1;" value="<%= typeof oferta !== 'undefined' && oferta && oferta.Empresa ? oferta.Empresa.Distrito : '' %>"></div>

            <div class="section-title" style="margin-top: 40px;">CONDICIONES</div>
            <div class="row"><label class="input-label">Experiencia:</label> <input type="number" id="experiencia" style="flex: 1;" value="<%= typeof oferta !== 'undefined' && oferta ? oferta.Experiencia : '' %>"></div>
            <div class="row"><label class="input-label">Pago Mes:</label> <input type="number" id="pagoMes" style="flex: 1;" value="<%= typeof oferta !== 'undefined' && oferta ? oferta.PagoMensual : '' %>"></div>
        </div>

        <div class="col" style="width: 55%;">
            <div class="section-title">PERFIL SOLICITADO</div>
            <div class="row"><label style="width: 90px;">Formación:</label> <input type="text" id="formacion" style="flex: 1;" value="<%= typeof oferta !== 'undefined' && oferta && oferta.Requisitos ? oferta.Requisitos.Formacion : '' %>"></div>
            
            <div class="section-title" style="display: flex; justify-content: space-between; align-items: center; margin-top: 30px;">
                <span>CONOCIMIENTOS TÉCNICOS</span> 
                <div style="display: flex; gap: 8px;">
                    <input type="text" id="inputNuevoConoc" placeholder="Ej: Python" style="width: 130px; font-size: 13px; padding: 8px 10px;">
                    <button type="button" class="btn-secundario btn-add-conoc" onclick="agregarConocimiento()">AÑADIR</button>
                </div>
            </div>
            
            <table>
                <thead>
                    <tr><th style="width: 15%;">#</th><th style="width: 50%;">HERRAMIENTA</th><th style="width: 35%;">ACCIÓN</th></tr>
                </thead>
                <tbody id="tablaConocimientos"></tbody>
            </table>
        </div>
    </div>

    <div class="buttons-bar">
        <button class="btn-crud btn-add" onclick="guardarOferta()">Guardar</button>
        <button class="btn-crud btn-update" onclick="actualizarOferta()">Actualizar</button>
        <button class="btn-crud btn-delete" onclick="eliminarOferta()">Eliminar</button>
        <button class="btn-crud btn-print" onclick="window.print()">Imprimir Ficha</button>
    </div>
</div>

<% 
    let conocimientosEJS = [];
    if (typeof oferta !== 'undefined' && oferta && oferta.Requisitos && oferta.Requisitos.Conocimientos) {
        conocimientosEJS = oferta.Requisitos.Conocimientos;
    }
%>
<input type="hidden" id="datosOcultosEJS" value="<%= JSON.stringify(conocimientosEJS) %>">

<script>
    function mostrarMensaje(texto) {
        const msg = document.getElementById("mensaje-feedback");
        msg.innerText = texto;
        msg.style.display = "block";
        setTimeout(() => { msg.style.display = "none"; }, 3000);
    }

    let listaConocimientos = JSON.parse(document.getElementById('datosOcultosEJS').value);

    function pintarTabla() {
        const tbody = document.getElementById('tablaConocimientos');
        tbody.innerHTML = '';
        if (listaConocimientos.length === 0) {
            tbody.innerHTML = '<tr><td colspan="3" style="color: #94a3b8; font-style: italic;">Sin conocimientos agregados</td></tr>';
            return;
        }
        listaConocimientos.forEach((conocimiento, index) => {
            tbody.innerHTML += `
                <tr>
                    <td style="font-weight: bold; color: #475569;">${index + 1}</td>
                    <td style="text-align: left; font-weight: 500;">${conocimiento}</td>
                    <td>
                        <button type="button" class="btn-tbl btn-tbl-edit" onclick="editarConocimiento(${index})">EDITAR</button>
                        <button type="button" class="btn-tbl btn-tbl-delete" onclick="quitarConocimiento(${index})">BORRAR</button>
                    </td>
                </tr>
            `;
        });
    }

    function agregarConocimiento() {
        const input = document.getElementById('inputNuevoConoc');
        const nuevo = input.value;
        if (nuevo && nuevo.trim() !== "") {
            listaConocimientos.push(nuevo.trim()); 
            pintarTabla(); 
            input.value = ''; 
        } else {
            mostrarMensaje("Por favor, escriba un conocimiento.");
        }
    }

    function editarConocimiento(index) {
        document.getElementById('inputNuevoConoc').value = listaConocimientos[index];
        listaConocimientos.splice(index, 1);
        pintarTabla();
    }

    function quitarConocimiento(index) {
        listaConocimientos.splice(index, 1); 
        pintarTabla(); 
    }

    pintarTabla();

    function obtenerDatosDelFormulario() {
        return {
            NroId: Number(document.getElementById('nroId').value),
            Puesto: document.getElementById('puesto').value,
            Empresa: {
                RazonSoc: document.getElementById('razonSoc').value,
                Direccion: document.getElementById('direccion').value,
                Distrito: document.getElementById('distrito').value
            },
            Experiencia: Number(document.getElementById('experiencia').value),
            PagoMensual: Number(document.getElementById('pagoMes').value),
            Requisitos: {
                Formacion: document.getElementById('formacion').value,
                Conocimientos: listaConocimientos 
            }
        };
    }

    async function crearNuevo() {
        try {
            const res = await fetch('/api/nuevo-id');
            const data = await res.json();
            document.querySelectorAll('input:not(#datosOcultosEJS)').forEach(input => input.value = ''); 
            document.getElementById('nroId').value = data.nuevoId; 
            listaConocimientos = []; 
            pintarTabla();
        } catch (error) { console.error(error); }
    }

    async function guardarOferta() {
        const datos = obtenerDatosDelFormulario();
        if (!datos.NroId || !datos.Puesto) return mostrarMensaje("Falta ingresar Nro ID o Puesto.");

        try {
            const res = await fetch('/api/ofertas', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(datos)
            });
            const resultado = await res.json();
            if (resultado.exito) {
                mostrarMensaje('Oferta creada correctamente.');
                setTimeout(() => { window.location.href = `/?buscarId=${datos.NroId}`; }, 1500);
            } else { mostrarMensaje(resultado.mensaje); }
        } catch (error) { console.error(error); }
    }

    async function actualizarOferta() {
        const datos = obtenerDatosDelFormulario();
        if (!datos.NroId) return mostrarMensaje("Busque una oferta primero.");

        try {
            const res = await fetch(`/api/ofertas/${datos.NroId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(datos)
            });
            const resultado = await res.json();
            if (resultado.exito) {
                mostrarMensaje('Oferta actualizada correctamente.');
            }
        } catch (error) { console.error(error); }
    }

    async function eliminarOferta() {
        const id = document.getElementById('nroId').value;
        if (!id) return mostrarMensaje("Ingrese un Nro ID para eliminar.");
        
        if (confirm(`¿Está seguro de eliminar la oferta ID: ${id}?`)) {
            try {
                const res = await fetch(`/api/ofertas/${id}`, { method: 'DELETE' });
                const resultado = await res.json();
                if (resultado.exito) {
                    mostrarMensaje('Oferta eliminada correctamente.');
                    setTimeout(() => { window.location.href = '/'; }, 1500);
                }
            } catch (error) { console.error(error); }
        }
    }
</script>
</body>
</html>