<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Lista General de Ofertas</title>
    <style>
        body { font-family: 'Segoe UI', Roboto, Arial, sans-serif; padding: 0; margin: 0; background-color: #f8fafc; color: #1e293b; }
        
        /* --- BARRA DE NAVEGACIÓN --- */
        .navbar-dark { background-color: #1f2937; color: white; display: flex; justify-content: space-between; align-items: center; padding: 15px 50px; box-shadow: 0 4px 10px rgba(0,0,0,0.3); margin-bottom: 40px; }
        .navbar-dark .nav-brand { font-size: 24px; font-weight: bold; letter-spacing: 1px; color: #fff; }
        .navbar-dark .nav-links { list-style: none; display: flex; gap: 40px; margin: 0; padding: 0; }
        .navbar-dark .nav-links li a { color: #d1d5db; text-decoration: none; font-size: 15px; font-weight: bold; transition: all 0.3s ease; }
        .navbar-dark .nav-links li a:hover { color: #ffffff; text-shadow: 0 0 12px #60a5fa, 0 0 20px #60a5fa; }
        
        /* --- CONTENEDOR PRINCIPAL --- */
        .container { max-width: 1000px; margin: auto; background: white; padding: 40px; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); border: 1px solid #f1f5f9; }
        
        .header-title { text-align: center; text-transform: uppercase; font-size: 18px; margin-bottom: 30px; color: #0f172a; letter-spacing: 0.5px; border-bottom: 2px solid #e2e8f0; padding-bottom: 15px; font-weight: 800; }
        
        /* --- TABLA MODERNA --- */
        table { width: 100%; border-collapse: separate; border-spacing: 0; margin-top: 10px; border: 1px solid #e2e8f0; border-radius: 8px; overflow: hidden; }
        th, td { padding: 14px 12px; text-align: center; font-size: 14px; }
        th { background-color: #f8fafc; color: #475569; font-weight: 700; text-transform: uppercase; font-size: 12px; border-bottom: 2px solid #e2e8f0; letter-spacing: 0.5px;}
        td { border-bottom: 1px solid #e2e8f0; color: #1e293b; }
        tr:last-child td { border-bottom: none; }
        tr:hover td { background-color: #f1f5f9; }
        
        /* --- BOTÓN ELEGIR --- */
        .btn-elegir { background-color: #10b981; color: white; padding: 8px 16px; text-decoration: none; border-radius: 6px; font-weight: bold; font-size: 12px; transition: all 0.2s; box-shadow: 0 4px 6px rgba(16, 185, 129, 0.2); display: inline-block; text-transform: uppercase;}
        .btn-elegir:hover { background-color: #059669; transform: translateY(-2px); }
    </style>
</head>
<body>

<nav class="navbar-dark">
    <div class="nav-brand">Portal Empleos Pro</div>
    <ul class="nav-links">
        <li><a href="/">Home (CRUD)</a></li>
        <li><a href="/lista">Lista General</a></li>
        <li><a href="/busqueda">Buscar x Conocimientos</a></li>
    </ul>
</nav>

<div class="container">
    <div class="header-title">Listado General de Ofertas de Empleo</div>
    
    <table>
        <thead>
            <tr>
                <th>Nro ID</th>
                <th>Empresa (Razón Social)</th>
                <th>Puesto Solicitado</th>
                <th>Pago Mensual</th>
                <th>Acción</th>
            </tr>
        </thead>
        <tbody>
            <% if (ofertas && ofertas.length > 0) { %>
                <% ofertas.forEach(oferta => { %>
                    <tr>
                        <td style="font-weight: bold; color: #475569;"><%= oferta.NroId %></td>
                        <td style="font-weight: 500;"><%= oferta.Empresa ? oferta.Empresa.RazonSoc : 'Sin Empresa' %></td>
                        <td><%= oferta.Puesto %></td>
                        <td style="color: #10b981; font-weight: bold;">S/ <%= oferta.PagoMensual %></td>
                        <td>
                            <a href="/?buscarId=<%= oferta.NroId %>" class="btn-elegir">ELEGIR</a>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="5" style="color: #64748b; font-style: italic; padding: 25px;">No hay ofertas registradas en la base de datos.</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</div>

</body>
</html>