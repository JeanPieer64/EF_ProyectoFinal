<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Búsqueda por Conocimientos</title>
    <style>
        body { font-family: 'Segoe UI', Roboto, Arial, sans-serif; padding: 0; margin: 0; background-color: #f8fafc; color: #1e293b; }
        
        .navbar-dark { background-color: #1f2937; color: white; display: flex; justify-content: space-between; align-items: center; padding: 15px 50px; box-shadow: 0 4px 10px rgba(0,0,0,0.3); margin-bottom: 40px; }
        .navbar-dark .nav-brand { font-size: 24px; font-weight: bold; letter-spacing: 1px; color: #fff; }
        .navbar-dark .nav-links { list-style: none; display: flex; gap: 40px; margin: 0; padding: 0; }
        .navbar-dark .nav-links li a { color: #d1d5db; text-decoration: none; font-size: 15px; font-weight: bold; transition: all 0.3s ease; }
        .navbar-dark .nav-links li a:hover { color: #ffffff; text-shadow: 0 0 12px #60a5fa, 0 0 20px #60a5fa; }
        
        .container { max-width: 950px; margin: auto; background: white; padding: 40px; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); border: 1px solid #f1f5f9; }
        
        h2 { text-align: center; text-transform: uppercase; font-size: 18px; margin-bottom: 30px; color: #0f172a; letter-spacing: 0.5px; border-bottom: 2px solid #e2e8f0; padding-bottom: 15px; font-weight: 800;}
        
        .search-container { background-color: #f1f5f9; padding: 20px 25px; border-radius: 8px; margin-bottom: 30px; display: flex; align-items: center; gap: 20px; font-size: 14px; font-weight: 600; color: #334155; border: 1px solid #e2e8f0; }
        .search-container input[type="text"] { flex: 1; padding: 10px 15px; border: 1px solid #cbd5e1; border-radius: 6px; outline: none; transition: all 0.3s; font-size: 14px; }
        .search-container input[type="text"]:focus { border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,0.2); background-color: #fff; }
        
        .radio-group { display: flex; gap: 15px; align-items: center; background: #fff; padding: 8px 15px; border-radius: 6px; border: 1px solid #cbd5e1;}
        .radio-group label { cursor: pointer; display: flex; align-items: center; gap: 5px; font-weight: 500;}
        
        .btn-buscar { padding: 10px 20px; background-color: #3b82f6; color: white; border: none; cursor: pointer; font-weight: bold; border-radius: 6px; transition: 0.2s; text-transform: uppercase; font-size: 13px; letter-spacing: 0.5px; box-shadow: 0 4px 6px rgba(59, 130, 246, 0.2); }
        .btn-buscar:hover { background-color: #2563eb; transform: translateY(-1px); }
        
        table { width: 100%; border-collapse: separate; border-spacing: 0; margin-bottom: 20px; border: 1px solid #e2e8f0; border-radius: 8px; overflow: hidden; }
        th, td { padding: 14px 12px; text-align: center; font-size: 14px; }
        th { background-color: #f8fafc; color: #475569; font-weight: 700; text-transform: uppercase; font-size: 12px; border-bottom: 2px solid #e2e8f0; letter-spacing: 0.5px;}
        td { border-bottom: 1px solid #e2e8f0; color: #1e293b; }
        tr:last-child td { border-bottom: none; }
        tr:hover td { background-color: #f1f5f9; }
        
        .btn-imprimir { float: right; padding: 12px 24px; background-color: #475569; color: white; border: none; cursor: pointer; font-weight: bold; border-radius: 6px; transition: 0.2s; text-transform: uppercase; font-size: 13px; margin-top: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .btn-imprimir:hover { background-color: #334155; transform: translateY(-2px); }
        
        .clearfix::after { content: ""; clear: both; display: table; }

        @media print { 
            .navbar-dark, .search-container, .btn-imprimir { display: none !important; } 
            .container { box-shadow: none; border: none; padding: 0; }
        }
    </style>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
</head>
<body>

<nav class="navbar-dark">
    <div class="nav-brand">Portal Empleos Pro</div>
    <ul class="nav-links">
        <li><a href="/">Home (CRUD)</a></li>
        <li><a href="/lista">Lista General</a></li>
        <li><a href="/busqueda">Buscar x Conocimientos</a></li>
    </ul>
</nav>

<div class="container" id="contenido-a-imprimir">
    <h2>Búsqueda de Ofertas de Empleo x Conocimientos</h2>

    <form action="/busqueda" method="GET" id="formulario-busqueda">
        <div class="search-container">
            <label>CONOCIMIENTOS:</label>
            <input type="text" name="conocimientos" placeholder="Ej: Java, C++, MySql" value="<%= typeof conocimientos !== 'undefined' ? conocimientos : '' %>">
            
            <div class="radio-group">
                <label>
                    <input type="radio" name="operador" value="AND" <%= typeof operador !== 'undefined' && operador === 'AND' ? 'checked' : '' %>> AND
                </label>
                <label>
                    <input type="radio" name="operador" value="OR" <%= typeof operador !== 'undefined' && operador === 'OR' ? 'checked' : (typeof operador === 'undefined' ? 'checked' : '') %>> OR
                </label>
            </div>
            
            <button type="submit" class="btn-buscar">BUSCAR OFERTAS</button>
        </div>
    </form>

    <table>
        <thead>
            <tr>
                <th>Nro</th>
                <th>Empresa</th>
                <th>Puesto</th>
                <th>Pago Mensual</th>
                <th>Experiencia</th>
            </tr>
        </thead>
        <tbody>
            <% if (typeof ofertas !== 'undefined' && ofertas.length > 0) { %>
                <% ofertas.forEach(oferta => { %>
                    <tr>
                        <td style="font-weight: bold; color: #475569;"><%= oferta.NroId %></td>
                        <td style="font-weight: 500;"><%= oferta.Empresa ? oferta.Empresa.RazonSoc : '-' %></td>
                        <td><%= oferta.Puesto %></td>
                        <td style="color: #10b981; font-weight: bold;">S/ <%= oferta.PagoMensual %></td>
                        <td><%= oferta.Experiencia %> años</td>
                    </tr>
                <% }) %>
            <% } else if (typeof conocimientos !== 'undefined') { %>
                <tr>
                    <td colspan="5" style="color: #64748b; font-style: italic; padding: 25px;">No se encontraron ofertas con esos requisitos.</td>
                </tr>
            <% } else { %>
                <tr>
                    <td colspan="5" style="color: #64748b; font-style: italic; padding: 25px;">Ingrese los conocimientos en la barra superior para iniciar la búsqueda.</td>
                </tr>
            <% } %>
        </tbody>
    </table>
    
    <div class="clearfix">
        <button type="button" class="btn-imprimir" onclick="generarPDF()">IMPRIMIR OFERTAS</button>
    </div>
</div>

<script>
    function generarPDF() {
        const elemento = document.getElementById('contenido-a-imprimir');
        
        document.getElementById('formulario-busqueda').style.display = 'none';
        document.querySelector('.btn-imprimir').style.display = 'none';

        const opciones = {
            margin:       0.5,
            filename:     'Busqueda_Ofertas_Pro.pdf',
            image:        { type: 'jpeg', quality: 0.98 },
            html2canvas:  { scale: 2 },
            jsPDF:        { unit: 'in', format: 'letter', orientation: 'landscape' }
        };

        html2pdf().set(opciones).from(elemento).save().then(() => {
            document.getElementById('formulario-busqueda').style.display = 'block';
            document.querySelector('.btn-imprimir').style.display = 'block';
        });
    }
</script>
</body>
</html>